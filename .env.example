# Genome Firewall — Supabase configuration
# Copy this file to `.env` and fill in the values from your Supabase project.
# NEVER commit the real `.env` (it is gitignored).
#
# Find these under: Supabase Dashboard → Project Settings → API

# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=

# The client-side key (safe to expose; RLS enforces access control):
#   - New projects: the "publishable" key  (sb_publishable_...)
#   - Older projects: the "anon" / public key  (a long eyJ... JWT)
# Do NOT use the "secret" / service_role key here — it bypasses RLS.
SUPABASE_KEY=

# Where Supabase redirects back to after Google OAuth. For local dev this is the
# Streamlit URL; add it to Supabase → Authentication → URL Configuration →
# Redirect URLs as well.
OAUTH_REDIRECT_URL=http://localhost:8501
